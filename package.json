{
  "name": "my-meeting-ai",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @meeting-ai/backend dev",
    "dev:worker": "pnpm --filter @meeting-ai/backend dev:worker",
    "dev:frontend": "pnpm --filter @meeting-ai/frontend dev",
    "dev:all": "pnpm dev:backend & pnpm dev:worker & pnpm dev:frontend & wait",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  }
}
