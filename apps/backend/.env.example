PORT=4000
DATABASE_URL=postgresql://meeting_ai:meeting_ai@localhost:5432/meeting_ai?schema=public
JWT_SECRET=change_me
REDIS_URL=redis://localhost:6379
UPLOAD_DIR=./uploads
MAX_MEETING_MINUTES=120
TRANSCRIPTION_PROVIDER=mock
POSTPROCESSING_PROVIDER=mock

# --- Провайдеры транскрипции ---

# OpenAI Whisper ($0.006/мин) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq Whisper Large V3 Turbo (бесплатно) — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini Flash (транскрипция + диаризация, ~$0.01/час) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gladia (10 часов/мес бесплатно) — https://app.gladia.io/
GLADIA_API_KEY=

# Deepgram Nova-2 ($0.0043/мин) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# AssemblyAI Universal-2 ($0.0062/мин) — https://www.assemblyai.com/app
ASSEMBLYAI_API_KEY=

# Whisper Local — URL OpenAI-совместимого сервера (faster-whisper-server, whisper.cpp)
# docker run -p 8080:8080 fedirz/faster-whisper-server:latest-cpu
WHISPER_LOCAL_URL=http://localhost:8080

# Ollama — локальный LLM/STT сервер
OLLAMA_BASE_URL=http://localhost:11434

# --- Интеграции ---
TELEGRAM_BOT_TOKEN=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=meeting-ai@example.local
